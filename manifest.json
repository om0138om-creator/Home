        },
        {
            "src": "icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    "screenshots": [
        {
            "src": "screenshots/screenshot-1.png",
            "sizes": "1080x1920",
            "type": "image/png",
            "label": "الشاشة الرئيسية"
        },
        {
            "src": "screenshots/screenshot-2.png",
            "sizes": "1080x1920",
            "type": "image/png",
            "label": "محرر النصوص"
        }
    ],
    "shortcuts": [
        {
            "name": "تصميم جديد",
            "short_name": "جديد",
            "description": "إنشاء تصميم جديد",
            "url": "/index.html?action=new",
            "icons": [
                {
                    "src": "icons/shortcut-new.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "فتح مشروع",
            "short_name": "فتح",
            "description": "فتح مشروع محفوظ",
            "url": "/index.html?action=open",
            "icons": [
                {
                    "src": "icons/shortcut-open.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "share_target": {
        "action": "/index.html",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "image",
                    "accept": ["image/*"]
                },
                {
                    "name": "font",
                    "accept": [".ttf", ".otf", ".woff", ".woff2"]
                }
            ]
        }
    },
    "file_handlers": [
        {
            "action": "/index.html",
            "accept": {
                "font/ttf": [".ttf"],
                "font/otf": [".otf"],
                "font/woff": [".woff"],
                "font/woff2": [".woff2"],
                "image/png": [".png"],
                "image/jpeg": [".jpg", ".jpeg"]
            }
        }
    ],
    "protocol_handlers": [
        {
            "protocol": "web+fontstudio",
            "url": "/index.html?project=%s"
        }
    ],
    "related_applications": [],
    "prefer_related_applications": false
}
