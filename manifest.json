{
    "name": "فونت ستوديو - Font Studio Pro",
    "short_name": "فونت ستوديو",
    "description": "تطبيق احترافي لتصميم الصور مع دعم كامل لخطوط OpenType Features - صمم صورك باحترافية مع أقوى محرر خطوط عربي",
    "version": "1.0.0",
    "start_url": "/index.html",
    "display": "standalone",
    "orientation": "any",
    "background_color": "#030712",
    "theme_color": "#6366f1",
    "scope": "/",
    "lang": "ar",
    "dir": "rtl",
    "categories": ["design", "graphics", "productivity", "utilities"],
    "icons": [
        {
            "src": "icons/icon-72.png",
            "sizes": "72x72",
            "type": "image/png",
